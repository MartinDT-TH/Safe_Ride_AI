{
  "ConnectionStrings": {
    "DefaultConnection": "",
    "Redis": ""
  },
  "Jwt": {
    "Issuer": "SafeRide",
    "Audience": "SafeRideMobile",
    "SecretKey": "CHANGE_ME",
    "AccessTokenMinutes": 15,
    "RefreshTokenDays": 30
  },
  "Authentication": {
    "Google": {
      "ClientIds": []
    }
  },
  "Infobip": {
    "BaseUrl": "https://api.infobip.com",
    "ApiKey": "",
    "From": "SafeRide"
  },
  "MapServices": {
    "PrimaryProvider": "VietMap",
    "VietMap": {
      "BaseUrl": "https://maps.vietmap.vn",
      "ApiKey": "",
      "RouteApiPath": "/api/route",
      "AutocompleteApiPath": "/api/autocomplete/v4",
      "GeocodeApiPath": "/api/search/v4",
      "PlaceApiPath": "/api/place/v4",
      "ReverseApiPath": "/api/reverse/v4",
      "TimeoutSeconds": 15
    },
    "GoogleMaps": {
      "BaseUrl": "https://routes.googleapis.com",
      "ApiKey": "",
      "RoutesApiUrl": "https://routes.googleapis.com/directions/v2:computeRoutes",
      "GeocodingApiUrl": "https://maps.googleapis.com/maps/api/geocode/json",
      "TimeoutSeconds": 15
    },
    "OpenRouteService": {
      "BaseUrl": "https://api.openrouteservice.org",
      "ApiKey": "",
      "DirectionsApiUrl": "https://api.openrouteservice.org/v2/directions/driving-car",
      "MatrixApiUrl": "https://api.openrouteservice.org/v2/matrix/driving-car",
      "AutocompleteApiUrl": "https://api.openrouteservice.org/geocode/autocomplete",
      "SearchApiUrl": "https://api.openrouteservice.org/geocode/search",
      "ReverseApiUrl": "https://api.openrouteservice.org/geocode/reverse",
      "TimeoutSeconds": 20
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}

